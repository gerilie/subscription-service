# App
APP_ENV=prod
APP_HOST=app
APP_PORT=8080

APP_READ_HEADER_TIMEOUT=5s
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=30s
APP_IDLE_TIMEOUT=120s

APP_RATE_LIMIT_REQUESTS_PER_SECOND=10
APP_RATE_LIMIT_BURST=30
APP_RATE_LIMIT_CLEANUP_INTERVAL=5m
APP_RATE_LIMIT_CLEANUP_MAX_IDLE=30m

# DB
POSTGRES_IMAGE=postgres:18.4-bookworm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=prod
POSTGRES_PASSWORD=prod
POSTGRES_DB=subscriptions

# Logger
LOGGER_LEVEL=info
